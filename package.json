{
  "name": "doc-scrape",
  "type": "module",
  "version": "1.0.6",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "description": "Browser extension to select HTML elements and convert them to Markdown.",
  "author": {
    "name": "OSpoon",
    "email": "zxin088@email.com",
    "url": "https://spoonly.cn/"
  },
  "license": "MIT",
  "scripts": {
    "dev": "extension dev --no-reload",
    "start": "extension start",
    "build": "extension build",
    "preview": "extension preview",
    "build:chrome": "extension build --browser chrome",
    "build:zip": "pnpm build:zip:chrome",
    "build:zip:chrome": "extension build --browser chrome --zip",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "bumpp",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "marked": "^18.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@antfu/ni": "^30.1.0",
    "@eslint-react/eslint-plugin": "^5.8.19",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/turndown": "^5.0.6",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "extension": "^3.18.4",
    "lint-staged": "^17.0.7",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,yml,yaml,md,css,less,scss}": "eslint --fix"
  }
}
