{
  "$schema": "https://json.schemastore.org/chrome-manifest.json",
  "chromium:manifest_version": 3,
  "firefox:manifest_version": 2,
  "version": "1.1.0",
  "name": "DocScrape - 网页内容转 Markdown",
  "description": "将网页内容整理为 Markdown，支持选取页面区域、整页导出、图片打包和 GitHub 发布。",
  "icons": {
    "16": "images/icon.png",
    "32": "images/icon.png",
    "48": "images/icon.png",
    "64": "images/icon.png",
    "128": "images/icon.png"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "chromium:service_worker": "background.ts",
    "firefox:scripts": ["background.ts"]
  },
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "DocScrape"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/scripts.tsx"],
      "run_at": "document_start"
    }
  ]
}
