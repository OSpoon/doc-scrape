{
  "$schema": "https://json.schemastore.org/chrome-manifest.json",
  "chromium:manifest_version": 3,
  "firefox:manifest_version": 2,
  "version": "1.0.7",
  "name": "DocScrape - 任意网页转 Markdown",
  "description": "在任意网页上选择 DOM 元素并转换为 Markdown 的浏览器扩展。",
  "icons": {
    "16": "images/icon.png",
    "32": "images/icon.png",
    "48": "images/icon.png",
    "64": "images/icon.png",
    "128": "images/icon.png"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "contextMenus",
    "storage"
  ],
  "background": {
    "chromium:service_worker": "background.ts",
    "firefox:scripts": ["background.ts"]
  },
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "DocScrape"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/scripts.tsx"]
    }
  ]
}
